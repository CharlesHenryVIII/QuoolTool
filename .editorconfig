# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Settings for every file
[*.{c,cpp,h,hpp}]
end_of_line = crlf
insert_final_newline = false
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Natvis
[*.{natvis}]
end_of_line = crlf
insert_final_newline = false
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
